{
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    { "source": "/pricing", "destination": "/pricing.html" },
    { "source": "/scanner", "destination": "/scanner-report.html" },
    { "source": "/waitlist", "destination": "/waitlist.html" },
    { "source": "/demo", "destination": "/demo.html" },
    { "source": "/how-it-works", "destination": "/how-it-works.html" },
    { "source": "/success", "destination": "/success.html" },
    { "source": "/cancel", "destination": "/cancel.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
      ]
    }
  ]
}
